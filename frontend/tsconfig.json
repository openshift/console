{
  "compilerOptions": {
    "skipLibCheck": true,
    "baseUrl": ".",
    "module": "esnext",
    "moduleResolution": "node",
    "outDir": "./public/dist/build/",
    "target": "es2021",
    "jsx": "react-jsx",
    "allowJs": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "typeRoots": ["node_modules/@types", "@types"],
    "types": ["node", "jest", "console"],
    "strictNullChecks": true
  },
  "exclude": [
    ".yarn",
    "**/node_modules",
    "public/dist",
    "packages/console-dynamic-plugin-sdk/scripts",
    "**/integration-tests",
    "**/integration-tests-cypress",
    "public",
    "__mocks__",
    "integration-tests",
    ".husky",
    "scripts",
    "i18n-scripts",
    "__tests__",
    "@types",
    ".vscode",
    ".yarn",
    "packages/console-dynamic-plugin-sdk",
    "packages/local-storage-operator-plugin",
    "packages/integration-tests-cypress",
    "packages/webterminal-plugin",
    "packages/vsphere-plugin",
    "packages/topology",
    "packages/pipelines-plugin",
    "packages/operator-lifecycle-manager",
    "packages/operator-lifecycle-manager-v1",
    "packages/knative-plugin",
    "packages/insights-plugin",
    "packages/helm-plugin",
    "packages/dev-console",
    "packages/container-security",
    "packages/console-telemetry-plugin",
    "packages/console-plugin-shared",
    "packages/service-binding-plugin",
    "packages/eslint-plugin-console",
    "packages/git-service",
    "packages/shipwright-plugin",
    "packages/metal3-plugin",
    "packages/gitops-plugin",
    "packages/console-shared",
    "packages/console-plugin-sdk",
    "packages/console-demo-plugin",
    "packages/console-app/src/components/guided-tour",
    "packages/console-app/src/components/vpa",
    "packages/console-app/src/components/volume-snapshot",
    "packages/console-app/src/components/user-preferences",
    "packages/console-app/src/components/quick-starts",
    "packages/console-app/src/components/resource-quota",
    "packages/console-app/src/components/nav",
    "packages/console-app/src/components/network-policies",
    "packages/console-app/src/components/detect-perspective",
    "packages/console-app/src/components/favorite",
    "packages/console-app/src/components/lightspeed",
    "packages/console-app/src/components/detect-namespace",
    "packages/console-app/src/components/access-modes",
    "packages/console-app/src/components/cluster-configuration",
    "packages/console-app/src/components/console-operator",
    "packages/console-app/src/components/modals",
    "packages/console-app/src/components/volume-modes",
    "packages/console-app/src/components/tour",
    "packages/console-app/src/components/tabs",
    "packages/console-app/src/components/storage",
    "packages/console-app/src/components/flags",
    "packages/console-app/src/components/file-upload",
    "packages/console-app/src/components/dashboards-page",
    "packages/console-app/src/components/admission-webhook-warnings"
  ],
  "include": ["**/*.js", "**/*.jsx", "**/*.ts", "**/*.tsx", "**/*.json"]
}

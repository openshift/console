{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "typeRoots": ["../@types", "../node_modules/@types"],
    "types": ["node", "console"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
